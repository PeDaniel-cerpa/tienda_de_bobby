root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2
quote_type = single

[*.{json,jsonc}]
indent_style = space
indent_size = 2

[tsconfig.json]
indent_style = space
indent_size = 2

[*.{html,css,scss,less}]
indent_style = space
indent_size = 2