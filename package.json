{
    "name": "tiendadebooby",
    "version": "1.0.0",
    "description": "Este es un proyecto enfocado en costruir una solucion de gestion de inventario y ventas para una tienda de barrio usando typeScript y node js, aplicando POO y los principios SOLID.",
    "keywords": [],
    "license": "ISC",
    "author": "daniel",
    "type": "commonjs",
    "main": "index.js",
    "scripts": {
        "build:web": "webpack --config-name browserConfig",
        "build:terminal": "webpack --config-name terminalConfig",
        "build:terminal:localStorage": "webpack --config-name terminalConfigLocalStorage",
        "go:terminal": "node ./dist/builds/terminal/build.terminal.js",
        "go:terminal:localStorage": "node ./dist/builds/terminal/build.terminal.local.js",
        "go:web": "webpack serve --config-name browserConfig --open",
        "build": "webpack",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "dependencies": {
        "dotenv": "^17.4.2",
        "node-localstorage": "^3.0.5",
        "scanf": "^1.2.1",
        "ts-node": "^10.9.2",
        "undici-types": "^7.18.2"
    },
    "devDependencies": {
        "@types/node": "^25.3.3",
        "@types/node-localstorage": "^1.3.3",
        "html-webpack-plugin": "^5.6.7",
        "rimraf": "^6.1.3",
        "string-replace-loader": "^3.3.0",
        "ts-loader": "^9.6.2",
        "typescript": "^6.0.3",
        "webpack": "^5.107.2",
        "webpack-cli": "^7.0.3",
        "webpack-dev-server": "^5.2.5"
    }
}
